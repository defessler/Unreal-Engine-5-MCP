# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.sln
*.suo
*.user
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj/
*.xcworkspace/

# UE build outputs
Binaries/
Intermediate/
DerivedDataCache/
Saved/
Build/
*.target
*.modules

# Source-built engine sibling — not committed to this repo
UnrealEngine/

# OS junk
Thumbs.db
.DS_Store
desktop.ini

# Scratch dirs
Temp/
tmp/
tpc-data/

# Claude Code session/local state — ignore everything except shared
# skills + agent definitions, which ship with the repo so any cloner
# gets the same fine-grained MCP usage guidance.
.claude/*
!.claude/skills/
!.claude/agents/

# BPIR-roundtrip emitted code (regenerated by BPIRRoundtrip tests).
# The module skeleton is committed (Build.cs + module entry .cpp +
# .gitkeep); everything else under Private/ is ephemeral test output.
Plugins/BlueprintReader/Source/BPRoundtripModule/Private/*
!Plugins/BlueprintReader/Source/BPRoundtripModule/Private/.gitkeep
!Plugins/BlueprintReader/Source/BPRoundtripModule/Private/BPRoundtripModule.cpp

# === Repo scope: BlueprintReader plugin + docs only ===
# This repo carries only the BlueprintReader plugin and its docs. The Lyra
# Starter Game scaffold that hosts the UBT build stays on disk locally (it is
# the build host) but is intentionally untracked here. To build from a fresh
# clone: acquire Lyra (Epic Games Launcher or a Lyra checkout) and mount this
# plugin into <Lyra>/Plugins/BlueprintReader (git submodule or a symlink).
/LyraStarterGame.uproject
/Source/
/GeneratedFromBP/
/Config/
/Platforms/
/Scripts/
# .github was untracked with the Lyra scaffold (#174). Re-allow only the MCP
# server CI workflow + the deployed Copilot instructions (a copy of the
# plugin's AGENTS.md, refreshed by Install-ClaudeAssets.ps1 — tracked so a
# fresh clone gives GitHub Copilot guidance without running the installer);
# everything else under .github stays local.
/.github/*
!/.github/workflows/
/.github/workflows/*
!/.github/workflows/mcp-tests.yml
!/.github/workflows/release.yml
!/.github/workflows/editor-build.yml
!/.github/copilot-instructions.md
/setup.bat

# All plugins except BlueprintReader (LyraGenerated + the Lyra game features).
/Plugins/*
!/Plugins/BlueprintReader/

# All Content except the two tracked BPRSeed test BPs.
/Content/*
!/Content/AI/
/Content/AI/*
!/Content/AI/BP_TestEnemy.uasset
!/Content/AI/BP_TestPickup.uasset

# Bundle artifacts produced by the (now-untracked) Lyra asset publish script.
lyra-assets-*.tar.zst
lyra-assets-*.tar.zst.sha256
