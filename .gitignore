# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.sln
*.suo
*.user
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj/
*.xcworkspace/

# UE build outputs
Binaries/
Intermediate/
DerivedDataCache/
Saved/
Build/
*.target
*.modules

# Source-built engine sibling — not committed to this repo
UnrealEngine/

# MCP server build outputs (now lives under the plugin so it ships as one unit)
Plugins/BlueprintReader/mcp-server/build/
Plugins/BlueprintReader/mcp-server/out/
Plugins/BlueprintReader/mcp-server/cmake-build-*/
Plugins/BlueprintReader/mcp-server/scripts/*-output.txt

# OS junk
Thumbs.db
.DS_Store
desktop.ini

# Claude Code session/local state — ignore everything except shared
# skills + agent definitions, which ship with the repo so any cloner
# gets the same fine-grained MCP usage guidance.
.claude/*
!.claude/skills/
!.claude/agents/

# BPIR-roundtrip emitted code (regenerated by BPIRRoundtrip tests).
# The module skeleton is committed (Build.cs + module entry .cpp +
# .gitkeep); everything else under Private/ is ephemeral test output.
# Defense-in-depth: ignore the whole Private/ subtree, then unignore the
# two files that have to stay tracked. This catches future emit dirs
# beyond Generated/ without having to extend the ignore list.
Plugins/BlueprintReader/Source/BPRoundtripModule/Private/*
!Plugins/BlueprintReader/Source/BPRoundtripModule/Private/.gitkeep
!Plugins/BlueprintReader/Source/BPRoundtripModule/Private/BPRoundtripModule.cpp

# Large content files unsuitable for direct GitHub hosting (>50MB).
# Re-fetch from Epic's Lyra distribution or set up Git LFS to track these.
Content/Effects/Textures/Flipbooks/SmokeSwirl_3_Flipbook_CHANNELPACK.uasset
Plugins/LyraExampleContent/Content/Materials/Textures/T_Rough_Concrete_Floor_ulmmbiuo_4K_N.uasset
Plugins/LyraExampleContent/Content/Megascans/Surfaces/Dirty_Painted_Concrete_Wall_vdqfcg3/T_Dirty_Painted_Concrete_Wall_vdqfcg3_4K_D.uasset
Plugins/LyraExampleContent/Content/Megascans/Surfaces/Dirty_Painted_Concrete_Wall_vdqfcg3/T_DirtyPaintedConcreteWall_vdqfcg3_4K_ORDp.uasset
