{
  "mcpServers": {
    "bp-reader": {
      "command": "<ABSOLUTE-PATH-TO>/Binaries/Win64/BlueprintReaderMcp.exe",
      "args": [],
      "env": {
        "BP_READER_BACKEND": "auto",
        "BP_READER_PROJECT": "<ABSOLUTE-PATH-TO>/YourGame.uproject",
        "BP_READER_ENGINE_DIR": "<ABSOLUTE-PATH-TO-YOUR-ENGINE>",
        "BP_READER_PREWARM": "1"
      }
    }
  }
}
