{
  "name": "blueprint-reader-toolbox",
  "version": "0.8.0",
  "description": "BlueprintReader MCP plugin installer, provider configurator, and tool tester",
  "main": "electron-dist/main.js",
  "scripts": {
    "prebuild:assets": "node scripts/copy-tools-json.js",
    "dev": "concurrently \"vite\" \"tsc -p electron/tsconfig.json -w\" \"wait-on http://localhost:5173 electron-dist/main.js && electron .\"",
    "build": "npm run prebuild:assets && vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder",
    "lint": "eslint src electron --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.defessler.blueprint-reader-toolbox",
    "productName": "BlueprintReader Toolbox",
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "artifactName": "BlueprintReaderToolbox.exe"
    },
    "directories": { "output": "../Binaries/Toolbox" },
    "files": ["dist/**", "electron-dist/**", "package.json"],
    "extraMetadata": { "main": "electron-dist/main.js" }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  }
}
